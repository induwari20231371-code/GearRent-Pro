<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: transparent;" stylesheets="@../styles/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.gearrentpro.controller.ManageEquipmentController">
   <children>
      <HBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- Form -->
            <VBox prefHeight="600.0" prefWidth="380.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <Label text="Equipment Details" textFill="#111111">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  
                  <HBox spacing="10.0">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Equipment ID" textFill="#666666" />
                              <TextField fx:id="txtId" promptText="E001" style="-fx-background-radius: 5; -fx-border-color: #c9c9c9;" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Category" textFill="#666666" />
                              <ComboBox fx:id="cmbCategory" prefWidth="150.0" promptText="Select" style="-fx-background-radius: 5; -fx-border-color: #c9c9c9;" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <VBox spacing="5.0">
                     <children>
                        <Label text="Name / Model" textFill="#666666" />
                        <TextField fx:id="txtName" promptText="Item name" style="-fx-background-radius: 5; -fx-border-color: #c9c9c9;" />
                     </children>
                  </VBox>

                  <HBox spacing="10.0">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Brand" textFill="#666666" />
                              <TextField fx:id="txtBrand" promptText="Brand" style="-fx-background-radius: 5; -fx-border-color: #c9c9c9;" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Year" textFill="#666666" />
                              <TextField fx:id="txtYear" promptText="YYYY" style="-fx-background-radius: 5; -fx-border-color: #c9c9c9;" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <HBox spacing="10.0">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Daily Price (LKR)" textFill="#666666" />
                              <TextField fx:id="txtDailyPrice" promptText="0.00" style="-fx-background-radius: 5; -fx-border-color: #c9c9c9;" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Deposit (LKR)" textFill="#666666" />
                              <TextField fx:id="txtDeposit" promptText="0.00" style="-fx-background-radius: 5; -fx-border-color: #c9c9c9;" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <VBox spacing="5.0">
                     <children>
                        <Label text="Status" textFill="#666666" />
                        <ComboBox fx:id="cmbStatus" prefWidth="350.0" promptText="Select Status" style="-fx-background-radius: 5; -fx-border-color: #c9c9c9;" />
                     </children>
                  </VBox>

                  <HBox spacing="10.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Button mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Save" />
                        <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #3a3a3a; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Update" />
                        <Button layoutX="90.0" layoutY="10.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #000000; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Delete" />
                     </children>
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
            
            <!-- Table -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <TableView fx:id="tblEquipment" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                      <TableColumn fx:id="colName" prefWidth="120.0" text="Name" />
                        <TableColumn fx:id="colBrand" prefWidth="80.0" text="Brand" />
                        <TableColumn fx:id="colCategory" prefWidth="80.0" text="Category" />
                        <TableColumn fx:id="colPrice" prefWidth="90.0" text="Day Price" />
                        <TableColumn fx:id="colDeposit" prefWidth="90.0" text="Deposit" />
                        <TableColumn fx:id="colStatus" prefWidth="80.0" text="Status" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</AnchorPane>
