<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.gearrentpro.controller.ManageBranchesController">
   <children>
      <TabPane tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" style="-fx-background-color: transparent;">
        <tabs>
          <Tab text="  Branch Management  ">
            <content>
              <AnchorPane style="-fx-background-color: #f5f5f5;">
                <children>
                  <HBox spacing="25.0" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="25.0" AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="25.0">
                    <children>
                      <VBox prefWidth="380.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                        <children>
                          <Label text="Branch Details" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111111;"/>
                          
                          <VBox spacing="5.0">
                            <Label text="Branch ID" style="-fx-font-weight: bold; -fx-text-fill: #666666; -fx-font-size: 12px;" />
                            <TextField fx:id="txtId" promptText="Auto Generated" editable="false" style="-fx-background-color: #eeeeee; -fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px;" />
                          </VBox>
                          
                          <VBox spacing="5.0">
                            <Label text="Branch Name *" style="-fx-font-weight: bold; -fx-text-fill: #666666; -fx-font-size: 12px;" />
                            <TextField fx:id="txtName" promptText="Enter branch name" style="-fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px; -fx-border-color: #c9c9c9; -fx-border-radius: 8;" />
                          </VBox>
                          
                          <VBox spacing="5.0">
                            <Label text="Address *" style="-fx-font-weight: bold; -fx-text-fill: #666666; -fx-font-size: 12px;" />
                            <TextField fx:id="txtAddress" promptText="Enter full address" style="-fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px; -fx-border-color: #c9c9c9; -fx-border-radius: 8;" />
                          </VBox>
                          
                          <VBox spacing="5.0">
                            <Label text="Contact Number" style="-fx-font-weight: bold; -fx-text-fill: #666666; -fx-font-size: 12px;" />
                            <TextField fx:id="txtContact" promptText="e.g., 011-2345678" style="-fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px; -fx-border-color: #c9c9c9; -fx-border-radius: 8;" />
                          </VBox>
                          
                          <HBox spacing="10.0" alignment="CENTER">
                            <padding><Insets top="15.0"/></padding>
                            <children>
                              <Button mnemonicParsing="false" onAction="#btnSaveOnAction" prefWidth="100.0" text="Save" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 20; -fx-cursor: hand;" />
                              <Button mnemonicParsing="false" onAction="#btnUpdateBranchOnAction" prefWidth="100.0" text="Update" style="-fx-background-color: #1f1f1f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 20; -fx-cursor: hand;" />
                              <Button mnemonicParsing="false" onAction="#btnDeleteOnAction" prefWidth="100.0" text="Delete" style="-fx-background-color: #000000; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 20; -fx-cursor: hand;" />
                            </children>
                          </HBox>
                          
                          <Button mnemonicParsing="false" onAction="#btnClearOnAction" prefWidth="330.0" text="Clear Form" style="-fx-background-color: #6f6f6f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;" />
                        </children>
                      </VBox>
                      
                      <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                        <children>
                          <Label text="All Branches" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111111;">
                            <padding><Insets bottom="15.0"/></padding>
                          </Label>
                          <TableView fx:id="tblBranches" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10;">
                            <columns>
                              <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                              <TableColumn fx:id="colName" prefWidth="180.0" text="Branch Name" />
                              <TableColumn fx:id="colAddress" prefWidth="250.0" text="Address" />
                              <TableColumn fx:id="colContact" prefWidth="120.0" text="Contact" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                          </TableView>
                        </children>
                      </VBox>
                    </children>
                  </HBox>
                </children>
              </AnchorPane>
            </content>
          </Tab>
          
          <Tab text="  System Users  ">
            <content>
              <AnchorPane style="-fx-background-color: #f5f5f5;">
                <children>
                  <HBox spacing="25.0" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="25.0" AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="25.0">
                    <children>
                      <VBox prefWidth="380.0" spacing="12.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                        <children>
                          <Label text="User Registration" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111111;"/>
                          
                          <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <Label text="User ID:" style="-fx-font-weight: bold; -fx-text-fill: #666666;" />
                            <Label fx:id="lblUserId" text="Auto" style="-fx-font-size: 14px; -fx-text-fill: #1f1f1f; -fx-font-weight: bold;" />
                          </HBox>
                          
                          <VBox spacing="5.0">
                            <Label text="Username *" style="-fx-font-weight: bold; -fx-text-fill: #666666; -fx-font-size: 12px;" />
                            <TextField fx:id="txtUsername" promptText="Enter username (min 4 chars)" style="-fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px; -fx-border-color: #c9c9c9; -fx-border-radius: 8;" />
                          </VBox>
                          
                          <VBox spacing="5.0">
                            <Label text="Password *" style="-fx-font-weight: bold; -fx-text-fill: #666666; -fx-font-size: 12px;" />
                            <PasswordField fx:id="txtPassword" promptText="Enter password (min 6 chars)" style="-fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px; -fx-border-color: #c9c9c9; -fx-border-radius: 8;" />
                          </VBox>
                          
                          <VBox spacing="5.0">
                            <Label text="Confirm Password *" style="-fx-font-weight: bold; -fx-text-fill: #666666; -fx-font-size: 12px;" />
                            <PasswordField fx:id="txtConfirmPassword" promptText="Re-enter password" style="-fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px; -fx-border-color: #c9c9c9; -fx-border-radius: 8;" />
                          </VBox>
                          
                          <VBox spacing="5.0">
                            <Label text="Role *" style="-fx-font-weight: bold; -fx-text-fill: #666666; -fx-font-size: 12px;" />
                            <ComboBox fx:id="cmbRole" prefWidth="330.0" promptText="Select Role" style="-fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 14px;" />
                          </VBox>
                          
                          <VBox spacing="5.0">
                            <Label text="Assigned Branch" style="-fx-font-weight: bold; -fx-text-fill: #666666; -fx-font-size: 12px;" />
                            <ComboBox fx:id="cmbUserBranch" prefWidth="330.0" promptText="Select Branch" style="-fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 14px;" />
                          </VBox>
                          
                          <HBox spacing="10.0" alignment="CENTER">
                            <padding><Insets top="10.0"/></padding>
                            <children>
                              <Button mnemonicParsing="false" onAction="#btnSaveUserOnAction" prefWidth="100.0" text="Create" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 20; -fx-cursor: hand;" />
                              <Button mnemonicParsing="false" onAction="#btnUpdateUserOnAction" prefWidth="100.0" text="Update" style="-fx-background-color: #1f1f1f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 20; -fx-cursor: hand;" />
                              <Button mnemonicParsing="false" onAction="#btnDeleteUserOnAction" prefWidth="100.0" text="Delete" style="-fx-background-color: #000000; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 20; -fx-cursor: hand;" />
                            </children>
                          </HBox>
                          
                          <Button mnemonicParsing="false" onAction="#btnClearUserOnAction" prefWidth="330.0" text="Clear Form" style="-fx-background-color: #6f6f6f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;" />
                        </children>
                      </VBox>
                      
                      <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                        <children>
                          <Label text="System Users" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111111;">
                            <padding><Insets bottom="15.0"/></padding>
                          </Label>
                          <TableView fx:id="tblUsers" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10;">
                            <columns>
                              <TableColumn fx:id="colUserId" prefWidth="60.0" text="ID" />
                              <TableColumn fx:id="colUsername" prefWidth="150.0" text="Username" />
                              <TableColumn fx:id="colRole" prefWidth="140.0" text="Role" />
                              <TableColumn fx:id="colUserBranch" prefWidth="120.0" text="Branch" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                          </TableView>
                        </children>
                      </VBox>
                    </children>
                  </HBox>
                </children>
              </AnchorPane>
            </content>
          </Tab>
        </tabs>
      </TabPane>
   </children>
</AnchorPane>
